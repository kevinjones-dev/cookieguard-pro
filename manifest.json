{
  "manifest_version": 3,
  "name": "CookieGuard Pro",
  "version": "1.0.0",
  "description": "Edit, manage, and auto-delete cookies. Open source, zero data collection, no tracking. Ever.",
  "permissions": ["cookies", "tabs", "storage", "alarms", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
